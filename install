#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
BIN_DIR="${CODY_BIN_DIR:-$HOME/.local/bin}"
SHIM="$BIN_DIR/cody-pro"

msg() {
  printf '%s\n' "$*"
}

need_cmd() {
  command -v "$1" >/dev/null 2>&1
}

if ! need_cmd curl; then
  msg "curl is required to install Bun. Install curl with your system package manager and rerun ./install."
  exit 1
fi

if ! need_cmd bun; then
  msg "Bun not found. Installing Bun for the current user..."
  curl -fsSL https://bun.sh/install | bash
  export PATH="$HOME/.bun/bin:$PATH"
fi

if ! need_cmd bun; then
  msg "Bun installation did not produce a usable bun command. Install Bun from https://bun.sh and rerun ./install."
  exit 1
fi

cd "$ROOT"
if [ -d "$ROOT/.git" ]; then
  if [ -n "$(git status --porcelain)" ]; then
    msg "Local changes detected. Skipping git pull to avoid overwriting work."
  else
    msg "Updating Cody Pro checkout..."
    git pull --ff-only || msg "git pull --ff-only failed. Continuing with the current checkout."
  fi
else
  msg "No .git directory found. Skipping repository update."
fi

msg "Installing Cody Pro dependencies..."
bun install

mkdir -p "$BIN_DIR"
cat > "$SHIM" <<EOF
#!/usr/bin/env bash
set -euo pipefail
ROOT="$ROOT"
export CODY_PRO=1
export PATH="\$HOME/.bun/bin:\$PATH"
if [ ! -d "\$ROOT" ]; then
  echo "Cody Pro checkout not found at \$ROOT" >&2
  exit 1
fi
cd "\$ROOT"
exec bun run --cwd "\$ROOT/packages/cody" --conditions=browser src/index.ts "\$@"
EOF
chmod +x "$SHIM"

case ":$PATH:" in
  *":$BIN_DIR:"*) ;;
  *)
    msg ""
    msg "Add this directory to PATH if it is not already there:"
    msg "  $BIN_DIR"
    ;;
esac

msg ""
msg "Cody Pro is installed."
msg "Start it with:"
msg "  cody-pro"
